<Window
    x:Class="ReoGridWorkSpace.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock"
    xmlns:custom="clr-namespace:ReoGridWorkSpace.Views.Custom"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ReoGridWorkSpace"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:xcad="http://xceed.com"
    Title="MainWindow"
    Width="1600"
    Height="900"
    mc:Ignorable="d">
    <DockPanel>
        <Menu
            Background="#001016"
            DockPanel.Dock="Top"
            Foreground="White">
            <!--<MenuItem Command="{Binding OpenCsvImportCommand}" Header="CSV Import" />
            <MenuItem Command="{Binding OpenPaymentViewerCommand}" Header="Payment Viewer" />
            <MenuItem Command="{Binding OpenTrendCommand}" Header="Trend" />
            <MenuItem Command="{Binding OpenWebBrowserCommand}" Header="Web Browser" />-->
        </Menu>
        <Grid>
            <Grid.Resources>
                <Style TargetType="TextBox">
                    <Setter Property="Background" Value="Transparent" />
                </Style>
            </Grid.Resources>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="40" />
            </Grid.RowDefinitions>
            <avalonDock:DockingManager x:Name="dockManager">
                <avalonDock:DockingManager.Theme>
                    <avalonDock:Vs2013DarkTheme />
                </avalonDock:DockingManager.Theme>
                <avalonDock:LayoutRoot>
                    <avalonDock:LayoutPanel x:Name="MainPanel" Orientation="Horizontal">
                        <avalonDock:LayoutDocumentPane>
                            <avalonDock:LayoutDocument Title="AI_徳川成績">
                                <custom:ReoGridSheet DataContext="{Binding ScoreViewModel}" />
                            </avalonDock:LayoutDocument>
                        </avalonDock:LayoutDocumentPane>
                        <avalonDock:LayoutDocumentPane>
                            <avalonDock:LayoutDocument Title="国名">
                                <custom:ReoGridSheet DataContext="{Binding CountryViewModel}" />
                            </avalonDock:LayoutDocument>
                        </avalonDock:LayoutDocumentPane>
                    </avalonDock:LayoutPanel>
                </avalonDock:LayoutRoot>
            </avalonDock:DockingManager>

            <Grid Grid.Row="1" Background="Gray">
                <Button Content="閉じる" Command="{Binding CloseCommand}" Width="120" Margin="0,4"/>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
