<Window
    x:Class="ReoGridWorkSpace.Views.AnchorableWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock"
    xmlns:custom="clr-namespace:ReoGridWorkSpace.Views.Custom"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ReoGridWorkSpace.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:xcad="http://xceed.com"
    Title="アンカー使用"
    Width="1600"
    Height="900"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>
        <avalonDock:DockingManager>
            <avalonDock:DockingManager.Theme>
                <avalonDock:Vs2013BlueTheme />
            </avalonDock:DockingManager.Theme>
            <avalonDock:LayoutRoot>
                <LayoutPanel>
                    <LayoutAnchorablePane>
                        <LayoutAnchorable Title="AI_徳川成績_アンカー版">
                            <custom:ReoGridSheet DataContext="{Binding ScoreViewModel}" />
                        </LayoutAnchorable>
                    </LayoutAnchorablePane>
                    <LayoutAnchorablePane>
                        <LayoutAnchorable Title="国名_アンカー版">
                            <custom:ReoGridSheet DataContext="{Binding CountryViewModel}" />
                        </LayoutAnchorable>
                    </LayoutAnchorablePane>
                </LayoutPanel>
            </avalonDock:LayoutRoot>
        </avalonDock:DockingManager>
        <Grid Grid.Row="1" Background="Gray">
            <Button
                Width="120"
                Margin="0,4"
                Command="{Binding CloseCommand}"
                Content="閉じる" />
        </Grid>
    </Grid>
</Window>
